<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>加班費精算機</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Microsoft JhengHei',sans-serif;background:#f0f2f5}
.container{max-width:390px;margin:0 auto;background:#fff;padding:16px;min-height:100vh}
h1{font-size:20px;text-align:center;margin-bottom:16px}

.row-flex{display:flex;gap:10px;margin-bottom:10px}
.col-half{flex:1}
label{font-size:14px;margin-bottom:4px;display:block}
input, select{width:100%;padding:10px;border:1px solid #ddd;border-radius:8px;font-size:16px;background:#fff}
input[type="number"]{height:44px}
input::placeholder{color:#aaa}
input[type="date"],input[type="month"]{height:44px}

.type-group{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:10px}
.type-btn{padding:10px 0;border:none;border-radius:8px;background:#eee;font-size:14px}
.type-btn.type-weekday.active{background:#3498db;color:#fff}
.type-btn.type-rest.active{background:#27ae60;color:#fff}
.type-btn.type-holiday.active{background:#e67e22;color:#fff}

.btn-group{display:flex;gap:8px;margin-bottom:16px}
.btn-group button{flex:1;padding:12px;border:none;border-radius:8px;color:#fff;font-size:16px}
.btn-group button:nth-child(1){background:#3498db}
.btn-group button:nth-child(2){background:#c0392b}
.btn-group button:nth-child(3){background:#27ae60}
.btn-group button:nth-child(4){background:#2980b9}

h2{font-size:16px;margin:8px 0}
table{width:100%;border-collapse:collapse;margin-bottom:16px;font-size:14px}
th,td{border:1px solid #eee;padding:8px;text-align:center}
th{background:#f5f7fa}
.btn-del{background:#e74c3c;color:#fff;border:none;border-radius:6px;padding:4px 8px;font-size:13px}

.total{background:#f8f9fa;padding:12px;border-radius:8px;font-weight:bold;color:#c0392b;margin-bottom:10px}
.stat-toggle{width:100%;text-align:left;padding:8px 0;border:none;background:transparent;color:#225599;font-size:15px;font-weight:bold;cursor:pointer}
.stat-box{margin-top:8px;display:none}
.stat-box.open{display:block}
.festival{font-size:12px;color:#e67e22;margin-bottom:10px;min-height:18px}
.dayStat{color:#0066cc;margin-top:8px;font-size:14px;line-height:1.8;white-space:pre-line}
.small-note{font-size:12px;color:#666;margin-top:8px;line-height:1.6;white-space:pre-line}

.history-panel{margin-top:16px;padding:12px;background:#edf7ff;border-radius:8px;display:none}
.month-block{margin-bottom:10px;padding:8px;border-bottom:1px solid #cce5ff}
.pagination{display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap}
.page-btn{padding:4px 8px;border:none;border-radius:6px;background:#cce5ff;font-size:12px}
.page-btn.active{background:#225599;color:#fff}
.btn-del-history{background:#992222;color:#fff;border:none;border-radius:6px;padding:4px 6px;font-size:12px;margin-top:6px}

.setting-wrap{margin-bottom:14px}
.setting-header{width:100%;text-align:left;padding:12px;background:#f7fbff;border:1px solid #b8d4f2;border-radius:10px 10px 0 0;border-bottom:none;cursor:pointer;font-weight:bold;color:#225599;font-size:15px}
.setting-box{border:1px solid #b8d4f2;border-top:none;border-radius:0 0 10px 10px;padding:12px;background:#f7fbff;display:none}
.setting-box.open{display:block}
.custom-only{display:none; margin-top:8px;}

.bottom-calc-toggle{width:100%;text-align:left;padding:10px 0;border-top:1px solid #ddd;margin-top:20px;color:#225599;font-size:16px;font-weight:bold;cursor:pointer}
.bottom-calc-box{background:#f0f8ff;padding:12px;border-radius:8px;margin-top:8px;display:none}
.bottom-calc-box.open{display:block}
.calc-res{margin-top:10px;font-size:14px;line-height:1.7}
.red-tip{color:#d81b60;margin-top:4px}
</style>
</head>
<body>
<div class="container">
    <h1>加班費精算機</h1>

    <div class="setting-wrap">
      <div class="setting-header" id="toggleHeader">薪資日期設定 ▼</div>
      <div class="setting-box" id="settingBox">
        <label>計薪模式</label>
        <select id="payMode">
            <option value="monthStart">月初（當月1日～月底）</option>
            <option value="monthEnd">月底（當月1日～月底）</option>
            <option value="custom" selected>自訂（上月24～本月23）</option>
        </select>

        <div class="row-flex custom-only" id="customRange">
            <div class="col-half">
                <label>薪資起始日 (上月)</label>
                <input type="number" inputmode="decimal" step="0.01" id="periodStartDay" min="1" max="31" value="24">
            </div>
            <div class="col-half">
                <label>薪資結束日 (本月)</label>
                <input type="number" inputmode="decimal" step="0.01" id="periodEndDay" min="1" max="31" value="23">
            </div>
        </div>

        <label>領薪日</label>
        <select id="payDayMode">
            <option value="monthStart">月初</option>
            <option value="monthEnd">月底</option>
            <option value="custom" selected>自訂</option>
        </select>
        <input class="custom-only" type="number" inputmode="decimal" step="0.01" id="payDay" min="1" max="31" value="5">
      </div>
    </div>

    <div class="row-flex">
        <div class="col-half">
            <label>基本時薪</label>
            <input type="number" inputmode="decimal" step="0.01" id="wage" value="215">
        </div>
        <div class="col-half">
            <label>日期</label>
            <input type="date" id="date">
        </div>
    </div>

    <div class="festival" id="festival"></div>

    <label>加班類型</label>
    <div class="type-group">
        <button class="type-btn type-weekday" onclick="selectType('weekday')">平日</button>
        <button class="type-btn type-rest" onclick="selectType('rest')">休息日</button>
        <button class="type-btn type-holiday" onclick="selectType('holiday')">國定假日</button>
    </div>

    <div class="row-flex">
        <div class="col-half">
            <label>加班時數</label>
            <input type="number" inputmode="decimal" step="0.5" id="hours" placeholder="平日可留空或填0">
        </div>
        <div class="col-half">
            <label>請假時數</label>
            <input type="number" inputmode="decimal" step="0.5" id="leaveHours" placeholder="可輸入 0.5、1、2、8">
        </div>
    </div>

    <div class="btn-group">
        <button onclick="add()">新增</button>
        <button onclick="resetAll()">重置</button>
        <button onclick="saveCurrentMonth()">存檔</button>
        <button onclick="showHistory()">記錄</button>
    </div>

    <h2>明細</h2>
    <table>
        <tr>
            <th>日期</th>
            <th>加班</th>
            <th>請假</th>
            <th>類</th>
            <th>金額</th>
            <th>刪除</th>
        </tr>
        <tbody id="list"></tbody>
    </table>

    <div class="total">
        平日工資：<span id="baseTotal">0.0000</span><br>
        加班費：<span id="otTotal">0.0000</span><br>
        請假扣款：<span id="leaveTotal">0.0000</span><br>
        結算金額：<span id="final">0</span>
        <button class="stat-toggle" id="statToggle">查看詳細統計 ▼</button>
        <div class="stat-box" id="statBox">
            <div class="dayStat" id="dayStat"></div>
            <div class="small-note">
備註：
點擊上方方框可展開/收合計薪區間設定，
選擇計薪模式自動偵測計算區間；
加班分平日、休息日、國定假日三種計價規則，
平日正常上班無加班請假填0即可，
明細會顯示全部紀錄，僅下方統計只計算當月。
            </div>
        </div>
    </div>

    <div class="history-panel" id="historyPanel">
      <h3 style="margin-bottom:10px">📅 各月薪資存檔明細</h3>
      <div class="pagination" id="pagination"></div>
      <div id="monthHistoryList"></div>
    </div>

    <div class="bottom-calc-toggle" id="bottomCalcToggle">薪資目標加班試算 ▼</div>
    <div class="bottom-calc-box" id="bottomCalcBox">
      <div style="margin:10px 0;">
        <div>✅ 該月不加班底薪：<span id="monthBaseSalary">0</span> 元</div>
        <div>📅 計薪週：<span id="monthRangeText"></span></div>
        <div>📆 平日：<span id="mWork">0</span>｜休息日：<span id="mRest">0</span>｜國定假日：<span id="mHol">0</span></div>
        <div class="red-tip">常態規則：平日每日2.5h｜休息日每日12h｜優先排休息日加班</div>
      </div>

      <label>目標總薪資</label>
      <input type="number" inputmode="decimal" step="0.01" id="monthTargetMoney" placeholder="例如42840">
      <button style="width:100%;margin-top:8px;padding:10px;border:none;border-radius:8px;background:#3498db;color:#fff" onclick="calcMonthOvertime()">計算所需加班</button>
      <div class="calc-res" id="monthCalcResult"></div>
    </div>
</div>

<script>
const TW_HOLIDAYS = {
  "2025-01-01":"元旦","2025-01-28":"除夕","2025-01-29":"春節","2025-01-30":"春節","2025-01-31":"春節","2025-02-01":"春節","2025-02-02":"春節","2025-02-03":"春節","2025-02-04":"春節","2025-02-28":"和平紀念日","2025-04-04":"兒童節/清明","2025-05-01":"勞動節","2025-05-31":"端午","2025-09-28":"教師節","2025-10-06":"中秋","2025-10-10":"國慶日","2025-10-25":"光復節","2025-12-25":"行憲紀念日",
  "2026-01-01":"元旦","2026-02-14":"春節","2026-02-15":"春節","2026-02-16":"除夕","2026-02-17":"春節","2026-02-18":"春節","2026-02-19":"春節","2026-02-20":"春節","2026-02-21":"春節","2026-02-22":"春節","2026-02-28":"和平紀念日","2026-04-03":"清明","2026-04-04":"兒童節","2026-04-05":"清明","2026-05-01":"勞動節","2026-06-19":"端午","2026-09-25":"中秋","2026-09-28":"教師節","2026-10-10":"國慶日","2026-10-25":"光復節","2026-12-25":"行憲紀念日"
};

let data = [];
let selectedType = 'weekday';
let lastHours = '';
let lastLeaveHours = '';
let savedMonthRecords = JSON.parse(localStorage.getItem('savedMonthRecords')) || {};
let currentViewMonth = null;

const typeShort = {weekday:'平', rest:'休', holiday:'國'};
const typeClass = {weekday:'type-weekday', rest:'type-rest', holiday:'type-holiday'};

const bottomToggle = document.getElementById('bottomCalcToggle');
const bottomBox = document.getElementById('bottomCalcBox');
bottomToggle.onclick = ()=>{
  bottomBox.classList.toggle('open');
  bottomToggle.innerText = bottomBox.classList.contains('open') ? '薪資目標加班試算 ▲' : '薪資目標加班試算 ▼';
};

const statToggle = document.getElementById('statToggle');
const statBox = document.getElementById('statBox');
statToggle.onclick = ()=>{
  statBox.classList.toggle('open');
  statToggle.innerText = statBox.classList.contains('open') ? '查看詳細統計 ▲' : '查看詳細統計 ▼';
};

document.getElementById('payMode').addEventListener('change', function(){
    const mode = this.value;
    document.getElementById('customRange').style.display = mode === 'custom' ? 'flex' : 'none';
    show();
    refreshMonthCalc();
});

document.getElementById('payDayMode').addEventListener('change', function(){
    const mode = this.value;
    document.getElementById('payDay').style.display = mode === 'custom' ? 'block' : 'none';
});

document.getElementById('periodStartDay').addEventListener('input',()=>{saveData();show();refreshMonthCalc();});
document.getElementById('periodEndDay').addEventListener('input',()=>{saveData();show();refreshMonthCalc();});
document.getElementById('wage').addEventListener('input',()=>{saveData();show();refreshMonthCalc();});

const toggleHeader = document.getElementById('toggleHeader');
const settingBox = document.getElementById('settingBox');
toggleHeader.onclick = ()=> settingBox.classList.toggle('open');

function getLastDayOfMonth(y, m){
    return new Date(y, m+1, 0).getDate();
}

function getCustomRangeByMonth(year, month){
  const payMode = document.getElementById('payMode').value;
  if(payMode === 'monthStart' || payMode === 'monthEnd'){
    const endDay = getLastDayOfMonth(year, month);
    const start = new Date(year, month, 1);
    const end = new Date(year, month, endDay);
    return {start,end};
  }else{
    const startDay = Number(document.getElementById('periodStartDay').value)||24;
    const endDay = Number(document.getElementById('periodEndDay').value)||23;
    const start = new Date(year, month-1, startDay);
    const end = new Date(year, month, endDay);
    return {start,end};
  }
}

function scanRangeRealDays(startDate, endDate){
    let work = 0, rest = 0, hol = 0;
    let current = new Date(startDate);
    const end = new Date(endDate);
    while(current <= end){
        const ymd = formatDate(current);
        const info = checkDate(ymd);
        const day = current.getDay();
        if(info.isHoliday) hol++;
        else if(day === 0 || day === 6) rest++;
        else work++;
        current.setDate(current.getDate()+1);
    }
    return {work,rest,hol};
}

function getBaseSalaryByRange(range){
  const wage = Number(document.getElementById('wage').value)||0;
  const days = scanRangeRealDays(range.start, range.end);
  return wage * 8 * days.work;
}

function loadData() {
  const saved = localStorage.getItem('overtimeData_final');
  if(saved) try{ data = JSON.parse(saved); }catch(e){ data = []; }
  document.getElementById('periodStartDay').value = '24';
  document.getElementById('periodEndDay').value = '23';
  document.getElementById('payDay').value = '5';
  document.getElementById('wage').value = '215';
  document.getElementById('payMode').value = 'custom';
  document.getElementById('payDayMode').value = 'custom';
  document.getElementById('customRange').style.display = 'flex';
  document.getElementById('payDay').style.display = 'block';

  const now = new Date();
  const todayYmd = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
  document.getElementById('date').value = todayYmd;

  const info = checkDate(todayYmd);
  document.getElementById('festival').textContent = info.holidayName ? `🎊 ${info.holidayName}` : '';
  let autoType = 'weekday';
  if(info.isHoliday) autoType = 'holiday';
  else if(info.isWeekend) autoType = 'rest';
  selectType(autoType);

  show();
  refreshMonthCalc();
}

function saveData() {
  localStorage.setItem('overtimeData_final', JSON.stringify(data));
  localStorage.setItem('defaultWage', document.getElementById('wage').value);
  localStorage.setItem('periodStartDay', document.getElementById('periodStartDay').value);
  localStorage.setItem('periodEndDay', document.getElementById('periodEndDay').value);
  localStorage.setItem('payDay', document.getElementById('payDay').value);
  localStorage.setItem('payMode', document.getElementById('payMode').value);
  localStorage.setItem('payDayMode', document.getElementById('payDayMode').value);
}

function saveCurrentMonth(){
  const mRange = getMonthRange(document.getElementById('date').value);
  const key = `${formatDate(mRange.start)}~${formatDate(mRange.end)}`;
  savedMonthRecords[key] = {
    periodStartDay: document.getElementById('periodStartDay').value,
    periodEndDay: document.getElementById('periodEndDay').value,
    payDay: document.getElementById('payDay').value,
    payMode: document.getElementById('payMode').value,
    payDayMode: document.getElementById('payDayMode').value,
    wage: document.getElementById('wage').value,
    records: [...data]
  };
  localStorage.setItem('savedMonthRecords', JSON.stringify(savedMonthRecords));
  alert('✅ 當前計薪區間已存檔');
  showHistory();
}

function checkDate(ymd) {
  const [y,m,d] = ymd.split('-').map(Number);
  const dt = new Date(y, m-1, d);
  const day = dt.getDay();
  const isWeekend = (day === 0 || day === 6);
  const holidayName = TW_HOLIDAYS[ymd] || '';
  return { isWeekend, isHoliday: !!holidayName, holidayName };
}

function compareDate(a, b) {
  return new Date(b.d).getTime() - new Date(a.d).getTime();
}

document.getElementById('date').addEventListener('change', function() {
  const ymd = this.value;
  const info = checkDate(ymd);

  document.getElementById('festival').textContent = info.holidayName ? `🎊 ${info.holidayName}` : '';

  let autoType = 'weekday';
  if(info.isHoliday) autoType = 'holiday';
  else if(info.isWeekend) autoType = 'rest';
  selectType(autoType);

  const currentRange = getMonthRange(ymd);
  const selectDate = new Date(ymd);
  if(selectDate > currentRange.end){
    alert('⚠️ 該日期超出當前計薪區間，建議先存檔再切換設定');
  }
  show();
  refreshMonthCalc();
});

function selectType(t) {
  selectedType = t;
  document.querySelectorAll('.type-btn').forEach(btn=>btn.classList.remove('active'));
  document.querySelector(`.${typeClass[t]}`).classList.add('active');
}

function formatDate(dt) {
  const y = dt.getFullYear();
  const m = String(dt.getMonth()+1).padStart(2,'0');
  const d = String(dt.getDate()).padStart(2,'0');
  return `${y}-${m}-${d}`;
}

function getMonthRange(dateStr) {
  const payMode = document.getElementById('payMode').value;
  const baseDate = new Date(dateStr);
  const year = baseDate.getFullYear();
  const monthIdx = baseDate.getMonth();

  if(payMode === 'monthStart' || payMode === 'monthEnd'){
    const lastDay = getLastDayOfMonth(year, monthIdx);
    return {start:new Date(year,monthIdx,1), end:new Date(year,monthIdx,lastDay)};
  }else{
    const startDay = Number(document.getElementById('periodStartDay').value)||24;
    const endDay = Number(document.getElementById('periodEndDay').value)||23;
    const dayNum = baseDate.getDate();
    if (dayNum >= startDay) {
      return {
        start: new Date(year, monthIdx, startDay),
        end: new Date(year, monthIdx + 1, endDay)
      };
    } else {
      return {
        start: new Date(year, monthIdx - 1, startDay),
        end: new Date(year, monthIdx, endDay)
      };
    }
  }
}

// ✅ 最終正確領薪日邏輯（完全對齊你公司）
function getPayDayDate(endDate){
  const mode = document.getElementById('payDayMode').value;
  const year = endDate.getFullYear();
  const endMonthIdx = endDate.getMonth();
  const payDayNum = Number(document.getElementById('payDay').value) || 5;

  if(mode === 'monthStart'){
    return new Date(year, endMonthIdx + 1, 1);
  }
  if(mode === 'monthEnd'){
    const nextMonth = endMonthIdx + 1;
    const last = getLastDayOfMonth(year, nextMonth);
    return new Date(year, nextMonth, last);
  }
  // 自訂模式：結束月份 +1 個月，5號領薪
  return new Date(year, endMonthIdx + 1, payDayNum);
}

function inMonthRange(ymd, rangeStart, rangeEnd) {
  const target = new Date(ymd).getTime();
  return target >= rangeStart.getTime() && target <= rangeEnd.getTime();
}

function countRangeDays(start, end) {
  const msPerDay = 24*60*60*1000;
  return Math.round((end.getTime() - start.getTime()) / msPerDay) + 1;
}

function calcAllDayTypeCount(start, end) {
  let weekdayCnt = 0, restCnt = 0, holidayCnt = 0;
  let current = new Date(start);
  while(current <= end){
    const info = checkDate(formatDate(current));
    if(info.isHoliday) holidayCnt++;
    else if(current.getDay()===0||current.getDay()===6) restCnt++;
    else weekdayCnt++;
    current.setDate(current.getDate()+1);
  }
  return {allWeekday:weekdayCnt, allRest:restCnt, allHoliday:holidayCnt};
}

function resetAll(){
  if(!confirm('確定清空所有加班紀錄？薪資設定會保留')) return;
  data = [];
  saveData();
  show();
  document.getElementById('hours').value = '';
  document.getElementById('leaveHours').value = '';
}

function add() {
  const d = document.getElementById('date').value;
  const t = selectedType;
  let h = document.getElementById('hours').value.trim();
  let leaveH = document.getElementById('leaveHours').value.trim();
  const wage = document.getElementById('wage').value;
  if(!d) return alert('請先選擇日期');
  if(!wage || Number(wage) <= 0) return alert('請填寫基本時薪');

  const currentRange = getMonthRange(d);
  const selectDate = new Date(d);
  if(selectDate > currentRange.end && !confirm('此日期超出計薪區間，確定新增？')) return;

  if(t === 'weekday') h = (!h || isNaN(parseFloat(h))) ? '0' : h;
  else if(!h || parseFloat(h) <= 0) return alert('休息日/國定假日需填寫加班時數');
  leaveH = (!leaveH || isNaN(parseFloat(leaveH))) ? '0' : leaveH;

  lastHours = h;
  lastLeaveHours = leaveH;
  const hourly = parseFloat(wage);
  const hNum = parseFloat(h);
  let otAmt = 0, r43=0,r53=0,r83=0,r10=0,r20=0,r30=0;

  if(t === 'weekday'){
    r43 = Math.min(hNum,2);
    r53 = Math.max(hNum-2,0);
    otAmt = r43*hourly*1.334 + r53*hourly*1.667;
  }else if(t === 'rest'){
    r43 = Math.min(hNum,2);
    r53 = Math.min(Math.max(hNum-2,0),6);
    r83 = Math.max(hNum-8,0);
    otAmt = r43*hourly*1.334 + r53*hourly*1.667 + r83*hourly*2.667;
  }else if(t === 'holiday'){
    r20 = Math.min(hNum,8);
    r43 = Math.min(Math.max(hNum-8,0),2);
    r53 = Math.max(hNum-10,0);
    otAmt = r20*hourly*2.0 + r43*hourly*1.334 + r53*hourly*1.667;
  }
  const leaveDeduct = hourly * parseFloat(leaveH);
  data.push({d,t,h,leaveH,ot:otAmt,leaveDeduct,r43,r53,r83,r10,r20,r30});
  data.sort(compareDate);
  saveData();
  show();
  document.getElementById('hours').value = '';
  document.getElementById('leaveHours').value = '';
}

function show() {
  const listDom = document.getElementById('list');
  listDom.innerHTML = '';
  let sumOT = 0, sumBase = 0, sumLeave = 0;
  let cntWeekdayWork = 0, cntWeekdayOT = 0;
  let cntRestOT = 0, cntHolidayOT = 0;
  let totalWeekdayHours = 0;
  let totalRestHours = 0, totalHolidayHours = 0;
  let total43=0,total53=0,total83=0,total10=0,total20=0,total30=0;

  const wage = parseFloat(document.getElementById('wage').value);
  const currentRange = getMonthRange(document.getElementById('date').value);
  const rangePayDay = getPayDayDate(currentRange.end);
  const totalRangeDays = countRangeDays(currentRange.start, currentRange.end);
  const dayTypeCount = calcAllDayTypeCount(currentRange.start, currentRange.end);
  const nowMonthData = [...data];

  nowMonthData.forEach(item=>{
    const otVal = Number(item.ot)||0;
    const deductVal = Number(item.leaveDeduct)||0;
    const hourVal = Number(item.h)||0;
    if(inMonthRange(item.d, currentRange.start, currentRange.end)){
      sumOT += otVal;
      sumLeave += deductVal;
      total43 += Number(item.r43||0);
      total53 += Number(item.r53||0);
      total83 += Number(item.r83||0);
      total10 += Number(item.r10||0);
      total20 += Number(item.r20||0);
      total30 += Number(item.r30||0);
      if(item.t === 'weekday'){
        totalWeekdayHours += hourVal;
        if(hourVal > 0) cntWeekdayOT++;
        else cntWeekdayWork++;
        sumBase += wage * 8;
      }else if(item.t === 'rest'){
        totalRestHours += hourVal;
        cntRestOT++;
      }else if(item.t === 'holiday'){
        totalHolidayHours += hourVal;
        cntHolidayOT++;
      }
    }
    let displayMoney = otVal;
    if(item.t === 'weekday') displayMoney = wage*8 + otVal - deductVal;
    listDom.innerHTML += `
    <tr>
      <td>${item.d}</td>
      <td>${item.h}</td>
      <td>${item.leaveH}</td>
      <td>${typeShort[item.t]}</td>
      <td>${displayMoney.toFixed(4)}</td>
      <td><button class="btn-del" onclick="del(${data.indexOf(item)})">刪</button></td>
    </tr>`;
  });
  const finalMoney = sumBase + sumOT - sumLeave;
  document.getElementById('baseTotal').innerText = sumBase.toFixed(4);
  document.getElementById('otTotal').innerText = sumOT.toFixed(4);
  document.getElementById('leaveTotal').innerText = sumLeave.toFixed(4);
  document.getElementById('final').innerText = Math.round(finalMoney);

  document.getElementById('dayStat').innerText =
`計薪區間：${formatDate(currentRange.start)} ~ ${formatDate(currentRange.end)}
領薪日：${formatDate(rangePayDay)}
區間總天數：${totalRangeDays}天
｜平日${dayTypeCount.allWeekday}｜休息日${dayTypeCount.allRest}｜國定假日${dayTypeCount.allHoliday}

▸ 區間出勤統計
平日加班天數：${cntWeekdayOT} 天
平日正常上下班：${cntWeekdayWork} 天
休息日加班天數：${cntRestOT} 天
國定假日加班天數：${cntHolidayOT} 天

▸ 各費率累計時數
4/3(H)        ${total43} H
5/3(H)        ${total53} H
8/3(H)        ${total83} H
1.0(H)        ${total10} H
2.0(H)        ${total20} H
3.0(H)        ${total30} H

▸ 區間工時總計
平日正常工時：${(cntWeekdayOT + cntWeekdayWork) * 8} 小時
平日加班總時：${totalWeekdayHours} 小時
休息日加班總時：${totalRestHours} 小時
國定假日加班總時：${totalHolidayHours} 小時`;
}

function refreshMonthCalc(){
  const dateStr = document.getElementById('date').value;
  if(!dateStr) return;
  const range = getMonthRange(dateStr);
  const daysInfo = scanRangeRealDays(range.start, range.end);
  const basePay = getBaseSalaryByRange(range);

  document.getElementById('monthBaseSalary').innerText = Math.round(basePay).toLocaleString();
  document.getElementById('monthRangeText').innerText = `${formatDate(range.start)} ~ ${formatDate(range.end)}`;
  document.getElementById('mWork').innerText = daysInfo.work;
  document.getElementById('mRest').innerText = daysInfo.rest;
  document.getElementById('mHol').innerText = daysInfo.hol;
  document.getElementById('monthCalcResult').innerHTML = '';
}

function calcMonthOvertime(){
  const dateStr = document.getElementById('date').value;
  const range = getMonthRange(dateStr);
  const basePay = getBaseSalaryByRange(range);
  const target = Number(document.getElementById('monthTargetMoney').value)||0;
  const wage = Number(document.getElementById('wage').value)||0;
  const resDom = document.getElementById('monthCalcResult');

  if(target <= 0){
    resDom.innerHTML = '<span style="color:red">請輸入有效的目標薪資金額</span>';
    return;
  }
  if(target <= basePay){
    resDom.innerHTML = `<span style="color:green">✅ 目標 ${target} 元 ≤ 無加班底薪 ${Math.round(basePay)} 元<br>不需要任何加班，正常出勤即可達標</span>`;
    return;
  }
  const needAdd = target - basePay;
  const dayWeekHr = 2.5;
  const dayRestHr = 12;
  const r1 = wage * 1.334;
  const r2 = wage * 1.667;
  const rRestAll = wage * 2.667;

  let weekDayIncome = 0;
  if(dayWeekHr <= 2) weekDayIncome = dayWeekHr * r1;
  else weekDayIncome = 2*r1 + (dayWeekHr - 2)*r2;
  const restDayIncome = dayRestHr * rRestAll;

  let remain = needAdd;
  let text = `<div>
💸 該區間無加班底薪：${Math.round(basePay)} 元<br>
🎯 目標薪資：${target} 元<br>
📌 需額外賺取金額：${Math.round(needAdd)} 元<br><br>
【常態加班規則】
• 平日每日固定加班 2.5 小時
• 休息日固定加班 12 小時
✅ 排班優先順序：休息日優先加班<br><br>
【建議排班數量】<br>`;

  const restDayCount = Math.floor(remain / restDayIncome);
  remain -= restDayCount * restDayIncome;
  const weekDayCount = remain > 0 ? Math.ceil(remain / weekDayIncome) : 0;

  if(restDayCount > 0) text += `• 休息日加班 ${restDayCount} 天（每日12小時）<br>`;
  if(weekDayCount > 0) text += `• 平日加班 ${weekDayCount} 天（每日2.5小時）<br>`;
  text += '</div>';
  resDom.innerHTML = text;
}

function showHistory(){
  const panel = document.getElementById('historyPanel');
  const listBox = document.getElementById('monthHistoryList');
  const pageBox = document.getElementById('pagination');
  if(panel.style.display === 'block'){
    panel.style.display = 'none';
    return;
  }
  panel.style.display = 'block';
  listBox.innerHTML = '';
  pageBox.innerHTML = '';
  const monthKeys = Object.keys(savedMonthRecords).sort((a,b)=>new Date(b.split('~')[0]) - new Date(a.split('~')[0]));
  if(monthKeys.length === 0){
    listBox.innerHTML = '<div style="text-align:center;color:#666;padding:10px">尚無任何存檔紀錄</div>';
    return;
  }
  monthKeys.forEach(key=>{
    const btn = document.createElement('button');
    btn.className = 'page-btn';
    if(key === currentViewMonth) btn.classList.add('active');
    btn.innerText = key;
    btn.onclick = ()=>{
      currentViewMonth = key;
      renderSingleSaveRecord(key);
    };
    pageBox.appendChild(btn);
  });
  renderSingleSaveRecord(monthKeys[0]);
}

function renderSingleSaveRecord(key){
  const rec = savedMonthRecords[key];
  let sBase=0,sOT=0,sLeave=0;
  rec.records.forEach(it=>{
    sOT += Number(it.ot)||0;
    sLeave += Number(it.leaveDeduct)||0;
    if(it.t === 'weekday') sBase += Number(rec.wage)*8;
  });
  const totalCalc = sBase + sOT - sLeave;
  document.getElementById('monthHistoryList').innerHTML = `
    <div class="month-block">
      <strong>${key}</strong><br>
      時薪：${rec.wage}｜計薪模式：${rec.payMode}
      平日工資：${sBase.toFixed(2)}｜加班費：${sOT.toFixed(2)}｜請假扣款：${sLeave.toFixed(2)}<br>
      區間結算總金額：<b style="color:#c0392b">${Math.round(totalCalc)}</b>
      <button class="btn-del-history" onclick="delSave('${key}')">刪除此存檔</button>
    </div>
  `;
}

function delSave(key){
  if(!confirm(`確定刪除存檔 ${key}？刪除無法復原`)) return;
  delete savedMonthRecords[key];
  localStorage.setItem('savedMonthRecords', JSON.stringify(savedMonthRecords));
  currentViewMonth = null;
  showHistory();
}

function del(index){
  data.splice(index,1);
  saveData();
  show();
  if(document.getElementById('historyPanel').style.display === 'block') showHistory();
}

window.onload = loadData;
